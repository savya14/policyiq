# PolicyIQ environment variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# Groq API key — get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Admin panel password — set a strong password
ADMIN_PASSWORD=your_admin_password_here

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# Frontend URL for CORS (set to your Vercel/HF Spaces URL in production)
# Leave empty for local dev — localhost:5173 is always allowed
FRONTEND_URL=

# ── RAG tuning (optional overrides) ─────────────────────────────────────────
# Minimum FAISS relevance score [0–1] to allow generation.
SIMILARITY_THRESHOLD=0.25

# Maximum conversation turns kept in per-session memory.
MAX_HISTORY_TURNS=8
